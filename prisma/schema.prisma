generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String               @id @default(cuid())
  name                   String?
  email                  String?              @unique
  password               String?
  role                   Role                 @default(EMPLOYEE)
  isActive               Boolean              @default(true)
  departmentId           String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  assetsAllocated        Allocation[]
  bookings               Booking[]
  maintenanceRequests    MaintenanceRequest[]
  transferRequestsSent   TransferRequest[]    @relation("TransferRequestedBy")
  transferRequestsTarget TransferRequest[]    @relation("TransferTargetUser")
  department             Department?          @relation(fields: [departmentId], references: [id])
  auditsAssigned         AuditCycle[]         @relation("AuditAssignees")
}

model Department {
  id                     String            @id @default(cuid())
  name                   String            @unique
  isActive               Boolean           @default(true)
  headId                 String?           @unique
  parentDeptId           String?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  assetsAllocated        Allocation[]      @relation("DepartmentAllocations")
  parent                 Department?       @relation("DepartmentHierarchy", fields: [parentDeptId], references: [id])
  children               Department[]      @relation("DepartmentHierarchy")
  transferRequestsTarget TransferRequest[] @relation("TransferTargetDepartment")
  users                  User[]
}

model AssetCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]
}

model Asset {
  id                 String               @id @default(cuid())
  name               String
  assetTag           String               @unique
  serialNumber       String?
  acquisitionDate    DateTime?
  acquisitionCost    Float?
  condition          String?
  location           String?
  photoUrl           String?
  isSharedBookable   Boolean              @default(false)
  status             AssetStatus          @default(AVAILABLE)
  categoryId         String
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  allocations        Allocation[]
  category           AssetCategory        @relation(fields: [categoryId], references: [id])
  auditRecords       AuditRecord[]
  bookings           Booking[]
  maintenanceHistory MaintenanceRequest[]
}

model Allocation {
  id                 String            @id @default(cuid())
  assetId            String
  userId             String?
  departmentId       String?
  expectedReturnDate DateTime?
  returnDate         DateTime?
  status             String            @default("ACTIVE")
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  asset              Asset             @relation(fields: [assetId], references: [id])
  department         Department?       @relation("DepartmentAllocations", fields: [departmentId], references: [id])
  user               User?             @relation(fields: [userId], references: [id])
  transferRequests   TransferRequest[]
}

model TransferRequest {
  id                 String        @id @default(cuid())
  allocationId       String
  requestedById      String
  targetUserId       String?
  targetDepartmentId String?
  status             RequestStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  allocation         Allocation    @relation(fields: [allocationId], references: [id])
  requestedBy        User          @relation("TransferRequestedBy", fields: [requestedById], references: [id])
  targetDepartment   Department?   @relation("TransferTargetDepartment", fields: [targetDepartmentId], references: [id])
  targetUser         User?         @relation("TransferTargetUser", fields: [targetUserId], references: [id])
}

model Booking {
  id        String   @id @default(cuid())
  assetId   String
  userId    String
  startTime DateTime
  endTime   DateTime
  status    String   @default("UPCOMING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  asset     Asset    @relation(fields: [assetId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model MaintenanceRequest {
  id             String            @id @default(cuid())
  assetId        String
  requestedById  String
  issue          String
  priority       String
  photoUrl       String?
  status         MaintenanceStatus @default(PENDING)
  technicianName String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  asset          Asset             @relation(fields: [assetId], references: [id])
  requestedBy    User              @relation(fields: [requestedById], references: [id])
}

model AuditCycle {
  id        String        @id @default(cuid())
  name      String
  scope     String
  startDate DateTime
  endDate   DateTime
  status    AuditStatus   @default(OPEN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  records   AuditRecord[]
  auditors  User[]        @relation("AuditAssignees")
}

model AuditRecord {
  id           String             @id @default(cuid())
  auditCycleId String
  assetId      String
  status       VerificationStatus
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  asset        Asset              @relation(fields: [assetId], references: [id])
  auditCycle   AuditCycle         @relation(fields: [auditCycleId], references: [id])
}

enum Role {
  EMPLOYEE
  DEPARTMENT_HEAD
  ASSET_MANAGER
  ADMIN
}

enum AssetStatus {
  AVAILABLE
  ALLOCATED
  RESERVED
  UNDER_MAINTENANCE
  LOST
  RETIRED
  DISPOSED
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MaintenanceStatus {
  PENDING
  APPROVED
  REJECTED
  IN_PROGRESS
  RESOLVED
}

enum AuditStatus {
  OPEN
  CLOSED
}

enum VerificationStatus {
  VERIFIED
  MISSING
  DAMAGED
}
